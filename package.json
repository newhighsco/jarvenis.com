{
  "name": "@newhighsco/jarvenis.com",
  "description": "Jarvenis website",
  "version": "1.23.151",
  "author": "New High Score",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/jarvenis.com"
  },
  "homepage": "https://jarvenis.com",
  "bugs": {
    "url": "https://github.com/newhighsco/jarvenis.com/issues"
  },
  "packageManager": "yarn@4.17.0",
  "files": [
    "public",
    "src",
    "next-sitemap.js",
    "next.config.js",
    "postcss.config.js",
    "site.config.js"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf {.next,public/{robots.txt,{atom,rss,sitemap*}.xml},.sourcebit-*cache.json}",
    "start": "next dev --webpack",
    "build": "next build --webpack",
    "postbuild": "next-sitemap",
    "test": "yarn lint",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:js": "eslint --cache .",
    "lint:css": "stylelint --cache --ignore-path .gitignore '**/*.?(s)css'",
    "format": "concurrently 'yarn:format:*'",
    "format:js": "yarn lint:js --fix",
    "format:css": "yarn lint:css --fix"
  },
  "dependencies": {
    "@newhighsco/chipset": "7.2.2",
    "@newhighsco/next-plugin-svgr": "3.0.172",
    "@newhighsco/press-start": "2.8.1",
    "concurrently": "10.0.3",
    "marked": "18.0.5",
    "next": "16.2.9",
    "next-compose-plugins": "2.2.1",
    "next-mdx-frontmatter": "0.0.4",
    "next-mdx-remote": "6.0.0",
    "next-rss": "1.0.1",
    "next-sitemap": "4.2.3",
    "postcss": "8.5.16",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sass": "1.101.0",
    "sourcebit": "0.11.1",
    "sourcebit-source-filesystem": "0.2.0",
    "sourcebit-target-next": "0.8.3",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@newhighsco/browserslist-config": "3.0.0",
    "@newhighsco/commitlint-config": "1.3.2",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.15",
    "@newhighsco/lint-staged-config": "1.1.0",
    "@newhighsco/postcss-config": "4.0.58",
    "@newhighsco/prettier-config": "2.3.9",
    "@newhighsco/release-config": "1.5.1",
    "@newhighsco/stylelint-config": "4.0.49",
    "@newhighsco/svgr-config": "1.0.0",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "eslint": "10.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.3",
    "semantic-release": "25.0.5",
    "stylelint": "17.14.0"
  },
  "browserslist": [
    "extends @newhighsco/browserslist-config"
  ],
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "prettier": "@newhighsco/prettier-config",
  "release": {
    "extends": "@newhighsco/release-config"
  },
  "stylelint": {
    "extends": [
      "@newhighsco/stylelint-config"
    ]
  }
}
